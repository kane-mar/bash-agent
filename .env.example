# Provider API key (set exactly one)
# OPENROUTER_API_KEY=sk-or-...
# DEEPSEEK_API_KEY=sk-...
# OPENAI_API_KEY=sk-...

# Provider (optional: auto-detected from which key is set)
# PROVIDER=openrouter

# Model (optional: per-provider defaults exist)
# MODEL=gpt-4o

# System prompt (optional: the agent has a sensible default)
# SYSTEM_PROMPT="You are a coding agent in a bash environment..."
